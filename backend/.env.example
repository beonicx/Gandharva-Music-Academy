# ══════════════════════════════════════════════════════════
# Gandharva Music Academy - Backend Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git (it's in .gitignore)

# ── Server Configuration ────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# Production URLs (uncomment when deploying):
# FRONTEND_URL=https://your-domain.com

# ── Email Configuration (Gmail) ─────────────────────────────
# Required for receiving contact form submissions via email

# Your Gmail address
EMAIL_USER=youracademy@gmail.com

# Gmail App Password (16 characters, no spaces)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification enabled
EMAIL_PASS=your_16_char_app_password

# Where enquiry emails should be sent
ACADEMY_EMAIL=youracademy@gmail.com

# ── WhatsApp Notifications (Optional) ───────────────────────
# Get automated WhatsApp alerts for new enquiries
# Requires Twilio account (free trial available)

# Twilio Account Credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# WhatsApp Numbers (include 'whatsapp:' prefix)
# Sandbox number format: whatsapp:+14155238886
WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp number (with country code, no spaces)
WHATSAPP_TO=whatsapp:+916388250645

# ══════════════════════════════════════════════════════════
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. Follow QUICKSTART_CHECKLIST.md for detailed setup
# ══════════════════════════════════════════════════════════
